{
  "name": "@advjs/editor",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "ADV.JS Editor",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --port 3001",
    "dev:pwa": "VITE_PLUGIN_PWA=true nuxt dev",
    "start": "node .output/server/index.mjs",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "postinstall": "nuxt prepare",
    "preview": "nuxt preview",
    "generate": "nuxt generate",
    "start:generate": "npx serve .output/public"
  },
  "dependencies": {
    "@dagrejs/dagre": "catalog:",
    "@google/model-viewer": "catalog:frontend",
    "@octokit/core": "catalog:",
    "@octokit/rest": "catalog:",
    "@vue-flow/background": "catalog:",
    "@vue-flow/controls": "catalog:",
    "@vue-flow/core": "catalog:frontend",
    "@vue-flow/minimap": "catalog:",
    "@vue-flow/node-resizer": "catalog:",
    "@vueuse/core": "catalog:frontend",
    "cos-js-sdk-v5": "catalog:",
    "pixi-painter": "catalog:frontend",
    "qrcode": "catalog:",
    "ua-parser-js": "catalog:"
  },
  "devDependencies": {
    "@advjs/core": "workspace:*",
    "@advjs/gui": "workspace:*",
    "@iconify-json/carbon": "catalog:icons",
    "@iconify-json/ep": "catalog:icons",
    "@iconify-json/mdi": "catalog:icons",
    "@iconify-json/svg-spinners": "catalog:icons",
    "@iconify-json/twemoji": "catalog:icons",
    "@nuxt/devtools": "catalog:build",
    "@nuxtjs/color-mode": "catalog:build",
    "@nuxtjs/i18n": "catalog:",
    "@pinia/nuxt": "catalog:build",
    "@tdesign-vue-next/nuxt": "catalog:",
    "@types/qrcode": "catalog:types",
    "@unocss/eslint-config": "catalog:build",
    "@unocss/nuxt": "catalog:build",
    "@vite-pwa/nuxt": "catalog:build",
    "@vueuse/nuxt": "catalog:build",
    "consola": "catalog:cli",
    "honeycomb-grid": "catalog:utils",
    "monaco-editor": "catalog:frontend",
    "nuxt": "catalog:build",
    "nuxt-auth-utils": "catalog:",
    "nuxt-monaco-editor": "catalog:",
    "pinia": "catalog:frontend",
    "simple-git": "catalog:",
    "tdesign-vue-next": "catalog:frontend"
  }
}
